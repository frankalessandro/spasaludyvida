---
import ServiceArt from "./ServiceArt.astro";
import { priceFrom, categoryMeta, type Service } from "../data/services";

interface Props {
  service: Service;
  featured?: boolean;
}

const { service, featured = false } = Astro.props;
const cat = categoryMeta[service.categoria];
---

<a
  href={`/servicios/${service.slug}`}
  class:list={[
    "group reveal relative flex flex-col overflow-hidden rounded-3xl hairline bg-plum-950/40 transition-all duration-500 hover:-translate-y-1.5",
    featured ? "lg:col-span-2 lg:flex-row" : "",
  ]}
  style="box-shadow: 0 24px 60px -40px var(--color-void);"
>
  <!-- Arte -->
  <ServiceArt
    service={service}
    class:list={[
      "shrink-0 transition-transform duration-700 group-hover:scale-[1.04]",
      featured ? "aspect-[16/10] lg:aspect-auto lg:w-1/2" : "aspect-[4/3]",
    ]}
  >
    <span
      class="absolute left-5 top-5 rounded-full border border-[color-mix(in_srgb,var(--color-gold-400)_35%,transparent)] bg-void/40 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-gold-200 backdrop-blur"
    >
      {cat.label}
    </span>
  </ServiceArt>

  <!-- Contenido -->
  <div class="flex flex-1 flex-col p-7 md:p-8">
    <h3 class="font-display text-3xl text-cream transition-colors group-hover:text-gold-200">
      {service.nombre}
    </h3>
    <p class="mt-3 flex-1 text-sm leading-relaxed text-silver-400">
      {service.descripcion_short}
    </p>

    <div class="mt-7 flex items-center justify-between border-t border-[color-mix(in_srgb,var(--color-silver-100)_8%,transparent)] pt-5">
      <div class="flex flex-col">
        <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-silver-400">Desde</span>
        <span class="font-display text-2xl text-gold">{priceFrom(service)}</span>
      </div>
      <span
        class="flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.2em] text-silver-300 transition-colors group-hover:text-gold-300"
      >
        Ver más
        <span class="transition-transform duration-500 group-hover:translate-x-1.5">→</span>
      </span>
    </div>
  </div>
</a>
