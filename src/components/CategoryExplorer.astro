---
// Explorador interactivo de tratamientos: filtro por categoría con reflujo
// animado vía GSAP Flip (en vez de tres grids estáticos apilados).
import ServiceCard from "./ServiceCard.astro";
import { services, categoryMeta, type Categoria } from "../data/services";

const tabs: { key: Categoria | "todos"; label: string }[] = [
  { key: "todos", label: "Todos" },
  { key: "facial", label: categoryMeta.facial.label },
  { key: "corporal", label: categoryMeta.corporal.label },
  { key: "salud", label: categoryMeta.salud.label },
];
---

<div data-explorer>
  <div class="reveal mb-12 flex flex-wrap justify-center gap-3">
    {
      tabs.map((t, i) => (
        <button
          type="button"
          data-filter-btn={t.key}
          class:list={["explorer-tab", i === 0 && "is-active"]}
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
    {
      services.map((s) => (
        <div data-category={s.categoria} class="contents">
          <ServiceCard service={s} />
        </div>
      ))
    }
  </div>
</div>

<script>
  import gsap from "gsap";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(Flip);

  function initExplorers() {
    document.querySelectorAll<HTMLElement>("[data-explorer]").forEach((root) => {
      const buttons = Array.from(root.querySelectorAll<HTMLElement>("[data-filter-btn]"));
      const items = Array.from(root.querySelectorAll<HTMLElement>("[data-category]"));

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          if (btn.classList.contains("is-active")) return;
          const filter = btn.dataset.filterBtn;
          buttons.forEach((b) => b.classList.toggle("is-active", b === btn));

          const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const state = reduce ? null : Flip.getState(items, { props: "opacity" });

          items.forEach((item) => {
            const show = filter === "todos" || item.dataset.category === filter;
            item.classList.toggle("hidden", !show);
          });

          if (state) {
            Flip.from(state, {
              duration: 0.65,
              ease: "power3.inOut",
              absolute: true,
              stagger: 0.03,
            });
          }
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initExplorers);
</script>

<style>
  .explorer-tab {
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-gold-400) 25%, transparent);
    padding: 0.65rem 1.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-silver-300);
    transition: all 0.35s ease;
  }
  .explorer-tab:hover {
    border-color: var(--color-gold-400);
    color: var(--color-gold-200);
  }
  .explorer-tab.is-active {
    background: linear-gradient(120deg, var(--color-gold-300), var(--color-gold-600));
    color: var(--color-void);
    border-color: transparent;
  }
</style>
