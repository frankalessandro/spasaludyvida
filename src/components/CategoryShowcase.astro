---
// Índice editorial de tratamientos que avanza con el scroll: la sección se
// pinea y cada categoría "vive" un tramo de scroll idéntico; entre categorías
// hay una transición más corta (curtain dorado + giro 3D de las tarjetas)
// ligada al scroll (scrub reversible), como un scrollytelling editorial en
// vez de un simple filtro por click.
// En móvil no se pinea (mala UX con scroll-jacking en pantallas chicas):
// se muestra un fallback simple en carriles arrastrables, igual que PillarsRail.
import ServiceCard from "./ServiceCard.astro";
import { services, categoryMeta, type Categoria } from "../data/services";

const order: Categoria[] = ["facial", "corporal", "salud"];
const roman = ["I", "II", "III"];

const groups = order.map((key) => ({
  key,
  meta: categoryMeta[key],
  items: services.filter((s) => s.categoria === key),
}));
---

<!-- ======================= Versión pineada (desktop) ======================= -->
<div data-cat-pin class="relative hidden lg:block">
  <div class="flex h-screen flex-col items-center justify-center py-6">
    <div class="grid w-full max-w-6xl gap-8 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)] lg:items-center xl:gap-10 xl:grid-cols-[0.8fr_1.2fr]">
      <!-- Índice de categorías -->
      <div>
        {
          groups.map((g, i) => (
            <button
              type="button"
              data-cat-btn={g.key}
              class:list={["cat-index-btn", i === 0 && "is-active"]}
            >
              <span class="cat-index-num font-display">{roman[i]}</span>
              <span class="min-w-0 flex-1">
                <span class="block font-display text-2xl leading-tight md:text-3xl">{g.meta.label}</span>
                <span class="mt-1 block text-sm leading-relaxed text-silver-400">{g.meta.blurb}</span>
                <span class="cat-index-track">
                  <span data-cat-fill class="cat-index-fill" />
                </span>
              </span>
              <span class="cat-index-count font-display">{String(g.items.length).padStart(2, "0")}</span>
            </button>
          ))
        }
      </div>

      <!-- Carril de la categoría activa -->
      <div class="relative">
        <div data-curtain class="curtain" aria-hidden="true"></div>

        <div class="mb-4 flex items-center justify-between text-[0.68rem] uppercase tracking-[0.3em] text-silver-500">
          <span>Sigue el scroll para explorar</span>
          <div class="flex items-center gap-5">
            <span class="font-display text-sm tracking-normal text-gold-300">
              <span data-index-current>01</span> / <span data-index-total>{String(groups.length).padStart(2, "0")}</span>
            </span>
            <div class="flex items-center gap-2">
              <button type="button" data-rail-prev class="rail-arrow" aria-label="Tratamientos anteriores">
                <svg viewBox="0 0 16 16" fill="none" class="h-3.5 w-3.5" aria-hidden="true">
                  <path d="M10.5 3 5.5 8l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
              <button type="button" data-rail-next class="rail-arrow" aria-label="Siguientes tratamientos">
                <svg viewBox="0 0 16 16" fill="none" class="h-3.5 w-3.5" aria-hidden="true">
                  <path d="m5.5 3 5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Misma distribución para todas las categorías: el ancho de card es
             fluido (1/1.6 del carril, tope 25rem) para que en cualquier ancho
             de desktop se vea 1 card completa + un peek claro de la siguiente,
             y siempre haya scroll lateral. -->
        <div data-rail class="drag-rail flex snap-x gap-5 overflow-x-auto pb-4">
          {
            groups.map((g) =>
              g.items.map((s) => (
                <div
                  data-cat-item
                  data-category={g.key}
                  class:list={[
                    "w-[min(25rem,calc((100%-1.25rem)/1.6))] shrink-0 snap-start",
                    g.key !== groups[0].key && "hidden",
                  ]}
                >
                  <ServiceCard service={s} />
                </div>
              ))
            )
          }
        </div>
        <!-- Indicador del scroll lateral (lo conecta Animations.astro) -->
        <div data-rail-progress class="rail-track mt-1">
          <span data-rail-fill class="rail-fill"></span>
        </div>
      </div>
    </div>

    <!-- Burbuja sutil de scroll -->
    <div data-scroll-hint class="pointer-events-none absolute inset-x-0 bottom-2 flex justify-center">
      <span class="scroll-hint-pill">
        <svg viewBox="0 0 16 24" fill="none" class="h-3.5 w-auto" aria-hidden="true">
          <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.2" />
          <circle cx="8" cy="7" r="1.6" fill="currentColor" class="scroll-hint-dot" />
        </svg>
        Sigue el scroll
      </span>
    </div>
  </div>
</div>

<!-- ======================= Fallback simple (móvil) ======================= -->
<div class="space-y-16 lg:hidden">
  {
    groups.map((g, i) => (
      <div>
        <div class="reveal mb-6 flex items-end justify-between gap-4">
          <div class="flex items-baseline gap-4">
            <span class="font-display text-sm text-gold-500/70">{roman[i]}</span>
            <div>
              <span class="block font-display text-3xl text-cream">{g.meta.label}</span>
              <span class="mt-1 block text-sm text-silver-400">{g.meta.blurb}</span>
            </div>
          </div>
          <span class="swipe-hint pb-1">Desliza</span>
        </div>
        <div class="reveal drag-rail flex snap-x gap-5 overflow-x-auto pb-4">
          {g.items.map((s) => (
            <div class="w-[78vw] shrink-0 snap-start sm:w-80">
              <ServiceCard service={s} />
            </div>
          ))}
        </div>
        <div data-rail-progress class="rail-track mt-2">
          <span data-rail-fill class="rail-fill" />
        </div>
      </div>
    ))
  }
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initShowcases() {
    document.querySelectorAll<HTMLElement>("[data-cat-pin]").forEach((pinEl) => {
      const buttons = Array.from(pinEl.querySelectorAll<HTMLElement>("[data-cat-btn]"));
      const fills = Array.from(pinEl.querySelectorAll<HTMLElement>("[data-cat-fill]"));
      const rail = pinEl.querySelector<HTMLElement>("[data-rail]");
      const curtain = pinEl.querySelector<HTMLElement>("[data-curtain]");
      const currentEl = pinEl.querySelector<HTMLElement>("[data-index-current]");
      const totalEl = pinEl.querySelector<HTMLElement>("[data-index-total]");
      const hint = pinEl.querySelector<HTMLElement>("[data-scroll-hint]");
      if (!rail || !curtain || !buttons.length) return;

      const allItems = Array.from(rail.querySelectorAll<HTMLElement>("[data-cat-item]"));
      const total = buttons.length;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const itemsFor = (idx: number) =>
        allItems.filter((el) => el.dataset.category === buttons[idx].dataset.catBtn);

      if (totalEl) totalEl.textContent = String(total).padStart(2, "0");

      let current = 0;
      const setActive = (idx: number) => {
        if (idx === current) return;
        current = idx;
        const filter = buttons[idx].dataset.catBtn;
        allItems.forEach((el) => el.classList.toggle("hidden", el.dataset.category !== filter));
        buttons.forEach((b, i) => b.classList.toggle("is-active", i === idx));
        if (currentEl) currentEl.textContent = String(idx + 1).padStart(2, "0");
        rail.scrollTo({ left: 0, behavior: "auto" });
        // Refresca la barra de progreso lateral (el ancho scrolleable cambió)
        rail.dispatchEvent(new Event("scroll"));
      };

      // Flechas de carousel: avanzan/retroceden una card y se deshabilitan en
      // los extremos. setActive dispara "scroll" al resetear, así se refrescan.
      const prev = pinEl.querySelector<HTMLButtonElement>("[data-rail-prev]");
      const next = pinEl.querySelector<HTMLButtonElement>("[data-rail-next]");
      if (prev && next) {
        const step = () => {
          const card = rail.querySelector<HTMLElement>("[data-cat-item]:not(.hidden)");
          return (card ? card.getBoundingClientRect().width : rail.clientWidth * 0.6) + 20;
        };
        const updateArrows = () => {
          const max = rail.scrollWidth - rail.clientWidth;
          prev.disabled = rail.scrollLeft <= 2;
          next.disabled = rail.scrollLeft >= max - 2;
        };
        prev.addEventListener("click", () => rail.scrollBy({ left: -step(), behavior: "smooth" }));
        next.addEventListener("click", () => rail.scrollBy({ left: step(), behavior: "smooth" }));
        rail.addEventListener("scroll", updateArrows, { passive: true });
        window.addEventListener("resize", updateArrows, { passive: true });
        updateArrows();
      }

      // Reparto del scroll: cada categoría vive un tramo idéntico (1 unidad) y
      // entre categorías hay una transición más corta (T unidades) que avanza
      // y retrocede *con* el scroll (scrub), no como animación disparada.
      const T = 0.35;
      const unit = 1 + T;
      const units = total * unit - T;

      buttons.forEach((btn, idx) => {
        btn.addEventListener("click", () => {
          const st = ScrollTrigger.getById("cat-scrub");
          if (!st) {
            setActive(idx);
            return;
          }
          const target = st.start + ((idx * unit + 0.02) / units) * (st.end - st.start);
          window.scrollTo({ top: target, behavior: "smooth" });
        });
      });

      if (reduce) return;

      // Animations.astro orquesta un cleanup global de ScrollTrigger en cada
      // "astro:page-load" (mata todos los triggers para evitar duplicados al
      // navegar). Su <script> vive después de este en el DOM, así que su
      // listener corre después del nuestro dentro del mismo evento — si
      // creáramos el ScrollTrigger de forma síncrona aquí, quedaría destruido
      // al instante. Se difiere un frame para crearlo ya después de esa limpieza.
      requestAnimationFrame(() => {
        ScrollTrigger.matchMedia({
          "(min-width: 1024px)": () => {
            // Entrada de cards por categoría: timeline pausado cuyo progreso se
            // controla desde el scroll (reversible, sin "disparos").
            const tlIn = buttons.map((_, i) =>
              gsap
                .timeline({ paused: true })
                .fromTo(
                  itemsFor(i),
                  { opacity: 0, y: 26, rotateY: -8, transformPerspective: 800 },
                  { opacity: 1, y: 0, rotateY: 0, duration: 1, ease: "power2.out", stagger: 0.12 }
                )
            );
            tlIn[0].progress(1);

            const distance = () => window.innerHeight * 0.7 * units;

            const trigger = ScrollTrigger.create({
              id: "cat-scrub",
              trigger: pinEl,
              start: "top top",
              end: () => "+=" + distance(),
              pin: true,
              scrub: true,
              invalidateOnRefresh: true,
              onUpdate: (self) => {
                const u = self.progress * units;
                const i = Math.min(total - 1, Math.floor(u / unit));
                const local = u - i * unit;

                if (local <= 1 || i === total - 1) {
                  // Tramo estable: la categoría i quieta, sin curtain
                  setActive(i);
                  gsap.set(curtain, { scaleX: 0 });
                  tlIn[i].progress(1);
                } else {
                  // Transición i → i+1, scrubbed: primera mitad repliega las
                  // cards actuales mientras el curtain cubre; segunda mitad lo
                  // descubre y despliega las siguientes.
                  const p = (local - 1) / T;
                  if (p < 0.5) {
                    setActive(i);
                    gsap.set(curtain, { transformOrigin: "left center", scaleX: p * 2 });
                    tlIn[i].progress(1 - p * 2);
                  } else {
                    setActive(i + 1);
                    gsap.set(curtain, { transformOrigin: "right center", scaleX: (1 - p) * 2 });
                    tlIn[i + 1].progress((p - 0.5) * 2);
                  }
                }

                // Barras "stories": cada una se llena durante el tramo de su categoría
                fills.forEach((fill, k) => {
                  const p = Math.max(0, Math.min(1, u - k * unit));
                  fill.style.transform = `scaleX(${p})`;
                });
              },
            });

            if (hint) {
              gsap.to(hint, {
                opacity: 0,
                ease: "none",
                scrollTrigger: {
                  trigger: pinEl,
                  start: "top top",
                  end: () => "+=" + distance() * 0.12,
                  scrub: true,
                },
              });
            }

            return () => trigger.kill();
          },
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initShowcases);
</script>

<style>
  .cat-index-btn {
    display: flex;
    width: 100%;
    align-items: baseline;
    gap: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-silver-100) 10%, transparent);
    padding: 1.15rem 0.25rem;
    text-align: left;
    color: var(--color-silver-400);
    transition: color 0.4s ease, padding-left 0.4s ease;
  }
  .cat-index-btn:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-silver-100) 10%, transparent);
  }
  .cat-index-btn:hover {
    padding-left: 0.75rem;
  }
  .cat-index-num {
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-gold-400) 55%, transparent);
    transition: color 0.4s ease;
  }
  .cat-index-count {
    font-size: 1.1rem;
    color: var(--color-silver-600);
    transition: color 0.4s ease;
  }
  .cat-index-btn span:nth-child(2) > span:first-child {
    color: var(--color-silver-300);
    transition: color 0.4s ease;
  }
  .cat-index-btn.is-active {
    color: var(--color-silver-200);
    padding-left: 0.75rem;
  }
  .cat-index-btn.is-active .cat-index-num,
  .cat-index-btn.is-active .cat-index-count {
    color: var(--color-gold-300);
  }
  .cat-index-btn.is-active span:nth-child(2) > span:first-child {
    color: var(--color-gold-200);
  }

  /* Barra de progreso por categoría (estilo "stories") */
  .cat-index-track {
    margin-top: 0.6rem;
    display: block;
    height: 2px;
    width: 100%;
    max-width: 12rem;
    overflow: hidden;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-silver-100) 12%, transparent);
  }
  .cat-index-fill {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(90deg, var(--color-gold-400), var(--color-gold-200));
    will-change: transform;
  }

  /* Flechas de carousel del carril */
  .rail-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-gold-400) 30%, transparent);
    color: var(--color-gold-200);
    transition: background-color 0.3s ease, border-color 0.3s ease, opacity 0.3s ease;
  }
  .rail-arrow:hover:not(:disabled) {
    background: color-mix(in srgb, var(--color-gold-400) 14%, transparent);
    border-color: color-mix(in srgb, var(--color-gold-400) 55%, transparent);
  }
  .rail-arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .curtain {
    position: absolute;
    inset: 0;
    z-index: 20;
    transform: scaleX(0);
    background: linear-gradient(100deg, var(--color-gold-600), var(--color-gold-300) 45%, var(--color-gold-500));
    pointer-events: none;
    border-radius: 1.5rem;
  }

  /* Burbuja sutil de scroll */
  .scroll-hint-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-gold-400) 25%, transparent);
    background: color-mix(in srgb, var(--color-plum-950) 55%, transparent);
    backdrop-filter: blur(8px);
    padding: 0.5rem 1.1rem;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-silver-400);
  }
  .scroll-hint-dot {
    animation: scroll-hint-dot 1.8s ease-in-out infinite;
  }
  @keyframes scroll-hint-dot {
    0%,
    100% {
      transform: translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateY(5px);
      opacity: 0.3;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hint-dot {
      animation: none;
    }
  }
</style>
