---
// Raíl horizontal pineado: sustituye al marquee básico por un recorrido de scroll
// que avanza en horizontal mientras el usuario hace scroll vertical (GSAP + ScrollTrigger).
import { categoryMeta } from "../data/services";

const pillars = [
  {
    n: "01",
    title: categoryMeta.facial.label,
    text: categoryMeta.facial.blurb,
  },
  {
    n: "02",
    title: categoryMeta.corporal.label,
    text: categoryMeta.corporal.blurb,
  },
  {
    n: "03",
    title: categoryMeta.salud.label,
    text: categoryMeta.salud.blurb,
  },
  {
    n: "04",
    title: "Tecnología certificada",
    text: "Aparatología con registro INVIMA y protocolos diseñados a la medida de cada piel.",
  },
  {
    n: "05",
    title: "Experiencia exclusiva",
    text: "Un espacio privado, íntimo y sin prisas, pensado para tu comodidad absoluta.",
  },
];
---

<section data-pin-rail class="relative hidden overflow-hidden lg:block" aria-label="Pilares de la marca">
  <div class="flex h-screen items-center">
    <div data-pin-track class="flex w-max items-center gap-20 px-[8vw] will-change-transform">
      <div class="flex shrink-0 flex-col justify-center pr-10">
        <p class="eyebrow mb-4">Lo que nos define</p>
        <h2 class="font-display text-6xl leading-[0.95]">
          Cinco<br /><span class="text-gold">pilares</span>
        </h2>
      </div>
      {
        pillars.map((p) => (
          <article class="flex w-[26vw] min-w-[22rem] shrink-0 flex-col border-l border-[color-mix(in_srgb,var(--color-gold-400)_25%,transparent)] pl-8">
            <span class="font-display text-sm text-gold-500">{p.n}</span>
            <h3 class="mt-4 font-display text-4xl leading-tight text-cream">{p.title}</h3>
            <p class="mt-4 max-w-xs text-sm leading-relaxed text-silver-400">{p.text}</p>
          </article>
        ))
      }
      <div class="shrink-0 pl-4 pr-[6vw]">
        <span class="font-display text-8xl italic text-gold/25">✦</span>
      </div>
    </div>
  </div>
</section>

<!-- Versión móvil: carril arrastrable simple, sin pin (mejor UX táctil) -->
<section class="border-y border-[color-mix(in_srgb,var(--color-gold-400)_12%,transparent)] py-10 lg:hidden">
  <div class="drag-rail flex gap-6 overflow-x-auto px-5">
    {
      pillars.map((p) => (
        <article class="w-72 shrink-0 border-l border-[color-mix(in_srgb,var(--color-gold-400)_25%,transparent)] pl-6">
          <span class="font-display text-sm text-gold-500">{p.n}</span>
          <h3 class="mt-3 font-display text-2xl text-cream">{p.title}</h3>
          <p class="mt-2 text-sm text-silver-400">{p.text}</p>
        </article>
      ))
    }
  </div>
</section>
