---
import Layout from "../../layouts/Layout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ServiceArt from "../../components/ServiceArt.astro";
import {
  services,
  categoryMeta,
  formatCOP,
  businessInfo,
  type Service,
  type NivelInvasion,
} from "../../data/services";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const cat = categoryMeta[service.categoria];
const invasionScale = { Bajo: 1, Medio: 2, Alto: 3 } as const;

// Ficha técnica (solo campos con valor)
const ficha: { label: string; value: string }[] = [
  { label: "Duración", value: service.duracion ?? "" },
  { label: "Edad recomendada", value: `${service.edad_minima}–${service.edad_maxima} años` },
  { label: "Valoración previa", value: service.requiereConsulta ? "Requerida" : "No necesaria" },
].filter((f) => f.value);

// Confort durante la aplicación, según el nivel de invasión del propio servicio.
const comfortText: Record<NivelInvasion, string> = {
  Bajo: "Un proceso cómodo, sin dolor y con sensación de calor suave.",
  Medio: "Puede generar una leve molestia tolerable durante la aplicación.",
  Alto: "Un proceso más intenso, siempre bajo control profesional.",
};

// Narrativa del proceso — construida con los datos propios del servicio (sin inventar hechos)
const proceso = [
  {
    n: "01",
    title: "Valoración inicial",
    text: service.requiereConsulta
      ? "Evaluamos tu piel o cuerpo y tus objetivos antes de comenzar, para diseñar un protocolo a tu medida."
      : "No requiere valoración previa: puedes iniciar tu sesión directamente.",
  },
  {
    n: "02",
    title: "Preparación",
    text: `Recomendado para edades entre ${service.edad_minima} y ${service.edad_maxima} años. Te explicamos cada paso antes de comenzar para que llegues con total confianza.`,
  },
  {
    n: "03",
    title: "Aplicación del tratamiento",
    text: `${service.duracion ? `Sesión de ${service.duracion}, realizada` : "Sesión realizada"} por especialistas con equipos certificados. ${comfortText[service.nivel_invasion]}`,
  },
  {
    n: "04",
    title: "Cuidados posteriores",
    text: service.cuidados ?? "No requiere cuidados especiales adicionales tras la sesión.",
  },
  {
    n: "05",
    title: "Evolución",
    text: "Los resultados se hacen progresivamente más visibles en las semanas siguientes, a medida que tu piel o cuerpo responden al tratamiento.",
  },
  {
    n: "06",
    title: "Resultado",
    text: service.beneficios?.length
      ? `Notarás beneficios como ${service.beneficios.slice(0, 2).join(" y ").toLowerCase()}.`
      : service.descripcion_short,
  },
];

// Relacionados de la misma categoría (o los siguientes si no hay suficientes)
const related = services.filter((s) => s.slug !== service.slug);
const relatedSorted = [
  ...related.filter((s) => s.categoria === service.categoria),
  ...related.filter((s) => s.categoria !== service.categoria),
].slice(0, 6);

const galeriaCaptions = ["Equipo especializado", "Cabina de tratamiento", "Aplicación", "Resultado"];
---

<Layout title={`${service.nombre} — Spa Salud y Vida`} description={service.descripcion_short}>
  <!-- ============================ HERO SERVICIO (split sticky) ============================ -->
  <section class="relative overflow-hidden pt-36">
    <div class="mx-auto grid max-w-7xl gap-14 px-5 pb-20 md:px-10 lg:grid-cols-[1fr_0.9fr] lg:pb-0">
      <!-- Columna texto -->
      <div class="lg:py-10">
        <nav class="reveal mb-8 flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-silver-500">
          <a href="/" class="transition-colors hover:text-gold-300">Inicio</a>
          <span class="text-gold-600">/</span>
          <a href="/#tratamientos" class="transition-colors hover:text-gold-300">{cat.label}</a>
          <span class="text-gold-600">/</span>
          <span class="text-silver-300">{service.nombre}</span>
        </nav>

        <p class="eyebrow reveal mb-5">{cat.eyebrow}</p>
        <h1 class="font-display text-6xl font-semibold leading-[0.92] md:text-7xl">
          {
            service.nombre.split(" ").map((w) => (
              <span class="kinetic-line"><span>{w}</span></span>
            ))
          }
        </h1>
        <p class="reveal mt-7 max-w-md text-lg leading-relaxed text-silver-300">
          {service.descripcion_short}
        </p>

        <div class="reveal mt-9">
          <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-silver-400">Desde</span>
          <p class="font-display text-5xl text-gold">
            <span data-count-to={service.precio_por_sesion} data-count-prefix="$">$0</span>
          </p>
          <span class="text-xs text-silver-500">por sesión — planes completos más abajo</span>
        </div>

        <div class="reveal mt-10 flex flex-wrap gap-4">
          <a href={businessInfo.whatsapp} target="_blank" rel="noopener" class="btn-gold">
            Reservar {service.nombre}
          </a>
          <a href="/#tratamientos" class="btn-outline">Ver otros tratamientos</a>
        </div>

        <!-- Intensidad -->
        <div class="reveal mt-12 max-w-xs">
          <div class="flex items-center justify-between text-xs uppercase tracking-[0.2em] text-silver-500">
            <span>Intensidad</span>
            <span class="text-gold-300">{service.nivel_invasion}</span>
          </div>
          <div class="mt-3 flex gap-1.5">
            {
              [1, 2, 3].map((i) => (
                <span
                  class:list={[
                    "h-1.5 flex-1 rounded-full",
                    i <= invasionScale[service.nivel_invasion] ? "bg-gold-500" : "bg-silver-700/40",
                  ]}
                />
              ))
            }
          </div>
        </div>
      </div>

      <!-- Columna arte: sticky, con marco definido para no diluir la estética -->
      <div
        class="reveal relative lg:sticky lg:top-28 lg:h-[calc(100vh-9rem)] min-h-[26rem]"
        data-parallax="-6"
      >
        <ServiceArt service={service} class="mask-organic hairline h-full w-full" />
        <div class="glass absolute inset-x-6 bottom-6 rounded-2xl px-6 py-5 sm:inset-x-10 sm:bottom-10">
          <p class="eyebrow mb-1">{cat.eyebrow}</p>
          <p class="font-display text-2xl text-cream sm:text-3xl">{service.nombre}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ SOBRE EL TRATAMIENTO ============================ -->
  <section class="relative py-24">
    <div class="mx-auto max-w-5xl px-5 md:px-10">
      <div class="grid gap-10 lg:grid-cols-[0.55fr_1fr] lg:items-start">
        <div class="reveal">
          <p class="eyebrow mb-5">En qué consiste</p>
          <h2 class="font-display text-4xl leading-[0.98] md:text-5xl">Sobre {service.nombre}</h2>
        </div>
        <p class="reveal border-l border-[color-mix(in_srgb,var(--color-gold-400)_25%,transparent)] pl-8 text-lg leading-relaxed text-silver-300 md:text-xl">
          {service.descripcion_long ?? service.descripcion_short}
        </p>
      </div>
    </div>

    <!-- Galería (espacio reservado para fotografía real de equipo y resultados) -->
    <div class="mx-auto mt-16 max-w-7xl px-5 md:px-10">
      <p class="eyebrow reveal mb-8">Por dentro</p>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 sm:auto-rows-[9.5rem]">
        <div class="reveal group relative col-span-2 row-span-2 aspect-square overflow-hidden rounded-[1.75rem] hairline sm:aspect-auto" data-parallax="-4">
          <ServiceArt service={service} monogram={false} class="h-full w-full" />
          <span class="absolute bottom-5 left-5 text-xs uppercase tracking-[0.2em] text-silver-100/85">
            {galeriaCaptions[0]}
          </span>
        </div>
        {
          galeriaCaptions.slice(1).map((caption, i) => (
            <div
              class="reveal group relative aspect-square overflow-hidden rounded-2xl hairline sm:aspect-auto"
              data-parallax={i % 2 === 0 ? "-8" : "-3"}
            >
              <ServiceArt service={service} monogram={false} class="h-full w-full" />
              <span class="absolute bottom-4 left-4 text-[0.65rem] uppercase tracking-[0.18em] text-silver-100/75">
                {caption}
              </span>
            </div>
          ))
        }
      </div>
      <p class="reveal mt-4 text-xs text-silver-600">Fotografía real de equipo y resultados, próximamente.</p>
    </div>

    <!-- Timeline vertical animado -->
    <div class="mx-auto mt-24 max-w-3xl px-5 md:px-10">
      <p class="eyebrow reveal mb-12 text-center">El proceso</p>
      <div class="relative pl-12">
        <div class="absolute left-[0.9rem] top-2 bottom-2 w-px bg-silver-700/30"></div>
        <div class="absolute left-[0.9rem] top-2 bottom-2 w-px origin-top scale-y-0 bg-gold-400" data-timeline-line></div>

        {
          proceso.map((p) => (
            <div class="reveal relative mb-14 last:mb-0">
              <span
                class="absolute -left-12 top-0 h-[1.9rem] w-[1.9rem] rounded-full border border-silver-600 bg-void transition-colors"
                data-timeline-dot
              />
              <span class="font-display text-sm text-gold-500">{p.n}</span>
              <h3 class="mt-2 font-display text-2xl text-cream md:text-3xl">{p.title}</h3>
              <p class="mt-2 max-w-xl text-silver-400">{p.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================ BENEFICIOS (lista tipográfica) ============================ -->
  {
    service.beneficios && service.beneficios.length > 0 && (
      <section class="relative py-20">
        <div class="mx-auto max-w-4xl px-5 md:px-10">
          <p class="eyebrow reveal mb-10">Beneficios</p>
          <ul>
            {service.beneficios.map((b, i) => (
              <li class="reveal relative flex items-baseline gap-6 py-6 sm:gap-10">
                <span class="font-display text-sm text-gold-500/70">{String(i + 1).padStart(2, "0")}</span>
                <p class="font-display text-2xl text-cream sm:text-3xl">{b}</p>
                <span
                  class="absolute inset-x-0 bottom-0 h-px origin-left scale-x-0 bg-gradient-to-r from-gold-400 via-gold-400/40 to-transparent"
                  data-line-draw
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- ============================ CUIDADOS / CONTRAINDICACIONES + FICHA ============================ -->
  <section class="relative py-16">
    <div class="mx-auto grid max-w-7xl gap-14 px-5 md:px-10 lg:grid-cols-[1.4fr_1fr]">
      <div class="grid gap-10 sm:grid-cols-2 sm:divide-x sm:divide-[color-mix(in_srgb,var(--color-gold-400)_14%,transparent)]">
        {
          service.cuidados && (
            <div class="reveal sm:pr-8">
              <p class="eyebrow mb-4">Cuidados</p>
              <span class="mb-5 block h-px w-10 origin-left scale-x-0 bg-gold-400" data-line-draw />
              <p class="text-sm leading-relaxed text-silver-300">{service.cuidados}</p>
            </div>
          )
        }
        {
          service.contraindicaciones && (
            <div class="reveal sm:pl-8">
              <p class="eyebrow mb-4">Contraindicaciones</p>
              <span class="mb-5 block h-px w-10 origin-left scale-x-0 bg-gold-400" data-line-draw />
              <p class="text-sm leading-relaxed text-silver-300">{service.contraindicaciones}</p>
            </div>
          )
        }
      </div>

      <aside class="reveal rounded-[2rem] hairline glass p-8">
        <p class="eyebrow mb-6">Ficha técnica</p>
        <dl class="space-y-5">
          {
            ficha.map((f) => (
              <div class="flex items-center justify-between gap-4 border-b border-[color-mix(in_srgb,var(--color-silver-100)_8%,transparent)] pb-5 last:border-0 last:pb-0">
                <dt class="text-sm text-silver-500">{f.label}</dt>
                <dd class="text-right font-display text-base font-semibold text-cream">{f.value}</dd>
              </div>
            ))
          }
        </dl>
        <a href={businessInfo.whatsapp} target="_blank" rel="noopener" class="btn-gold mt-8 w-full justify-center">
          Agendar cita
        </a>
        <p class="mt-4 text-center text-xs text-silver-500">Respuesta inmediata por WhatsApp</p>
      </aside>
    </div>
  </section>

  <!-- ============================ INVERSIÓN (planes) ============================ -->
  <section class="relative py-20">
    <div class="mx-auto max-w-5xl px-5 md:px-10">
      <div class="reveal mb-12 text-center">
        <p class="eyebrow mb-4">Inversión</p>
        <h2 class="font-display text-4xl md:text-5xl">Elige tu plan</h2>
      </div>

      <div
        class:list={[
          "grid gap-6",
          service.precio_tratamiento_completo ? "sm:grid-cols-2" : "sm:mx-auto sm:max-w-md",
        ]}
      >
        <div class="reveal relative flex flex-col rounded-[2rem] hairline glass p-9">
          <p class="eyebrow mb-8 text-silver-300">Sesión individual</p>
          <p class="text-silver font-display text-5xl leading-none">{formatCOP(service.precio_por_sesion)}</p>
          <p class="mt-3 text-[0.68rem] uppercase tracking-[0.2em] text-silver-500">Pago único · por sesión</p>
          <ul class="mt-8 space-y-4 border-t border-[color-mix(in_srgb,var(--color-silver-100)_10%,transparent)] pt-8 text-sm text-silver-300">
            <li class="flex items-start gap-3">
              <span class="mt-[0.4em] h-1.5 w-1.5 shrink-0 rounded-full bg-silver-400"></span>
              1 sesión completa de {service.nombre}
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-[0.4em] h-1.5 w-1.5 shrink-0 rounded-full bg-silver-400"></span>
              Valoración personalizada
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-[0.4em] h-1.5 w-1.5 shrink-0 rounded-full bg-silver-400"></span>
              Seguimiento post-tratamiento
            </li>
          </ul>
          <a href={businessInfo.whatsapp} target="_blank" rel="noopener" class="btn-outline mt-9 w-full justify-center">
            Reservar sesión
          </a>
        </div>

        {
          service.precio_tratamiento_completo && (
            <div
              class="reveal relative flex flex-col overflow-hidden rounded-[2rem] p-9 lg:-translate-y-2"
              style="border:1px solid color-mix(in srgb, var(--color-gold-400) 45%, transparent); background: linear-gradient(165deg, color-mix(in srgb, var(--color-gold-600) 18%, var(--color-plum-950)), var(--color-plum-950) 72%); box-shadow: 0 32px 70px -32px color-mix(in srgb, var(--color-gold-500) 55%, transparent);"
            >
              <span class="absolute right-7 top-7 rounded-full border border-[color-mix(in_srgb,var(--color-gold-400)_45%,transparent)] bg-void/50 px-3 py-1 text-[0.62rem] uppercase tracking-[0.2em] text-gold-200 backdrop-blur">
                Recomendado
              </span>
              <p class="eyebrow mb-8 text-gold-300">Tratamiento completo</p>
              <p class="text-gold font-display text-5xl leading-none">
                {typeof service.precio_tratamiento_completo === "number"
                  ? formatCOP(service.precio_tratamiento_completo)
                  : service.precio_tratamiento_completo}
              </p>
              <p class="mt-3 text-[0.68rem] uppercase tracking-[0.2em] text-silver-400">Protocolo completo</p>
              <ul class="mt-8 space-y-4 border-t border-[color-mix(in_srgb,var(--color-gold-400)_20%,transparent)] pt-8 text-sm text-silver-200">
                <li class="flex items-start gap-3">
                  <span class="mt-[0.4em] h-1.5 w-1.5 shrink-0 rounded-full bg-gold-400"></span>
                  Protocolo completo de {service.nombre}
                </li>
                <li class="flex items-start gap-3">
                  <span class="mt-[0.4em] h-1.5 w-1.5 shrink-0 rounded-full bg-gold-400"></span>
                  Seguimiento continuo de resultados
                </li>
                <li class="flex items-start gap-3">
                  <span class="mt-[0.4em] h-1.5 w-1.5 shrink-0 rounded-full bg-gold-400"></span>
                  Plan de cuidado personalizado
                </li>
              </ul>
              <a href={businessInfo.whatsapp} target="_blank" rel="noopener" class="btn-gold mt-9 w-full justify-center">
                Reservar plan completo
              </a>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ============================ RELACIONADOS (carrusel arrastrable) ============================ -->
  <section class="relative py-20">
    <div class="mx-auto max-w-7xl px-5 md:px-10">
      <div class="reveal mb-10 flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="eyebrow mb-3">Continúa explorando</p>
          <h2 class="font-display text-4xl md:text-5xl">También te puede gustar</h2>
        </div>
        <a href="/#tratamientos" class="text-sm uppercase tracking-[0.2em] text-gold-300 hover:text-gold-200">
          Ver todos →
        </a>
      </div>
    </div>
    <div class="drag-rail flex gap-7 overflow-x-auto px-5 pb-4 md:px-10">
      {
        relatedSorted.map((s) => (
          <div class="w-[20rem] shrink-0">
            <ServiceCard service={s} />
          </div>
        ))
      }
    </div>
  </section>
</Layout>
